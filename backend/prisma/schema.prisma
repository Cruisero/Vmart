generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  username          String?
  role              Role      @default(USER)
  avatar            String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  emailVerified     Boolean   @default(false) @map("email_verified")
  resetToken        String?   @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  verificationToken String?   @map("verification_token")
  referralAgentId   String?   @map("referral_agent_id")
  tenantId          String?   @map("tenant_id")
  permissions       String?   @db.LongText
  agent             Agent?
  orders            Order[]
  tenant            Tenant?
  tickets           Ticket[]
  referralAgent     Agent?    @relation("ReferredUsers", fields: [referralAgentId], references: [id])

  @@index([referralAgentId])
  @@index([tenantId])
  @@map("users")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  icon        String?
  sortOrder   Int       @default(0) @map("sort_order")
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  tenantId    String?   @map("tenant_id")
  products    Product[]

  @@map("categories")
}

model Product {
  id              String           @id @default(uuid())
  categoryId      String?          @map("category_id")
  name            String
  description     String?          @db.Text
  price           Decimal          @db.Decimal(10, 2)
  originalPrice   Decimal?         @map("original_price") @db.Decimal(10, 2)
  stock           Int              @default(0)
  soldCount       Int              @default(0) @map("sold_count")
  image           String?
  images          Json?
  status          Status           @default(ACTIVE)
  sortOrder       Int              @default(0) @map("sort_order")
  sortScore       Int              @default(0) @map("sort_score")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deliveryNote    String?          @map("delivery_note") @db.Text
  fullDescription String?          @map("full_description") @db.Text
  tags            Json?
  viewCount       Int              @default(0) @map("view_count")
  weight          Int              @default(0)
  wholesalePrices Json?            @map("wholesale_prices")
  tenantId        String?          @map("tenant_id")
  agentProducts   AgentProduct[]
  cards           Card[]
  orders          Order[]
  variants        ProductVariant[]
  category        Category?        @relation(fields: [categoryId], references: [id])
  tenant          Tenant?          @relation(fields: [tenantId], references: [id])

  @@index([categoryId], map: "idx_category")
  @@index([tenantId], map: "idx_tenant_id")
  @@map("products")
}

model ProductVariant {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  name            String
  price           Decimal  @db.Decimal(10, 2)
  originalPrice   Decimal? @map("original_price") @db.Decimal(10, 2)
  stock           Int      @default(0)
  sortOrder       Int      @default(0) @map("sort_order")
  status          Status   @default(ACTIVE)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  type            String?
  wholesalePrices Json?    @map("wholesale_prices")
  cards           Card[]
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_variants_product_id_fkey")
  @@map("product_variants")
}

model Card {
  id        String          @id @default(uuid())
  productId String          @map("product_id")
  content   String          @db.Text
  status    CardStatus      @default(AVAILABLE)
  orderId   String?         @map("order_id")
  soldAt    DateTime?       @map("sold_at")
  createdAt DateTime        @default(now()) @map("created_at")
  variantId String?         @map("variant_id")
  tenantId  String?         @map("tenant_id")
  order     Order?          @relation(fields: [orderId], references: [id])
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId], map: "cards_order_id_fkey")
  @@index([productId], map: "cards_product_id_fkey")
  @@index([variantId], map: "cards_variant_id_fkey")
  @@index([tenantId], map: "cards_tenant_id_fkey")
  @@map("cards")
}

model Order {
  id            String      @id @default(uuid())
  orderNo       String      @unique @map("order_no")
  userId        String?     @map("user_id")
  email         String
  productId     String      @map("product_id")
  productName   String      @map("product_name")
  quantity      Int         @default(1)
  unitPrice     Decimal     @map("unit_price") @db.Decimal(10, 2)
  totalAmount   Decimal     @map("total_amount") @db.Decimal(10, 2)
  status        OrderStatus @default(PENDING)
  paymentMethod String?     @map("payment_method")
  paymentNo     String?     @map("payment_no")
  paidAt        DateTime?   @map("paid_at")
  completedAt   DateTime?   @map("completed_at")
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent") @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  variantId     String?     @map("variant_id")
  variantName   String?     @map("variant_name")
  cancelledAt   DateTime?   @map("cancelled_at")
  usdtAmount    Decimal?    @map("usdt_amount") @db.Decimal(10, 2)
  bscUsdtAmount Decimal?    @map("bsc_usdt_amount") @db.Decimal(10, 2)
  remark        String?     @db.Text
  queryPassword String?     @map("query_password")
  tenantId      String?     @map("tenant_id")
  customerId    String?     @map("customer_id")
  agentOrder    AgentOrder?
  cards         Card[]
  customer      Customer?   @relation(fields: [customerId], references: [id])
  product       Product     @relation(fields: [productId], references: [id])
  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  user          User?       @relation(fields: [userId], references: [id])
  payment       Payment?
  tickets       Ticket[]

  @@index([productId], map: "orders_product_id_fkey")
  @@index([userId], map: "orders_user_id_fkey")
  @@index([tenantId], map: "orders_tenant_id_fkey")
  @@index([customerId])
  @@map("orders")
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique @map("order_id")
  paymentMethod String        @map("payment_method")
  amount        Decimal       @db.Decimal(10, 2)
  tradeNo       String?       @map("trade_no")
  status        PaymentStatus @default(PENDING)
  rawData       Json?         @map("raw_data")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Setting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String?  @db.Text
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Ticket {
  id               String          @id @default(uuid())
  ticketNo         String          @unique @map("ticket_no")
  userId           String?         @map("user_id")
  orderId          String?         @map("order_id")
  orderNo          String?         @map("order_no")
  type             TicketType
  subject          String
  status           TicketStatus    @default(OPEN)
  userUnreadCount  Int             @default(0) @map("user_unread_count")
  adminUnreadCount Int             @default(0) @map("admin_unread_count")
  userLastReadAt   DateTime?       @map("user_last_read_at")
  adminLastReadAt  DateTime?       @map("admin_last_read_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  closedAt         DateTime?       @map("closed_at")
  customerId       String?         @map("customer_id")
  tenantId         String?         @map("tenant_id")
  messages         TicketMessage[]
  customer         Customer?       @relation(fields: [customerId], references: [id])
  order            Order?          @relation(fields: [orderId], references: [id])
  user             User?           @relation(fields: [userId], references: [id])

  @@index([userId], map: "tickets_user_id_fkey")
  @@index([customerId])
  @@index([orderId], map: "tickets_order_id_fkey")
  @@index([tenantId])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  senderId  String?  @map("sender_id")
  isAdmin   Boolean  @default(false) @map("is_admin")
  content   String   @db.Text
  images    Json?
  createdAt DateTime @default(now()) @map("created_at")
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId], map: "ticket_messages_ticket_id_fkey")
  @@index([senderId], map: "ticket_messages_sender_id_fkey")
  @@map("ticket_messages")
}

model SiteVisit {
  id        String   @id @default(uuid())
  date      DateTime @unique
  visits    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_visits")
}

model SearchLog {
  id         String   @id @default(uuid())
  tenantId   String?  @map("tenant_id")
  keyword    String   @db.VarChar(120)
  count      Int      @default(1)
  lastUsedAt DateTime @default(now()) @map("last_used_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([tenantId, keyword], map: "search_logs_tenant_keyword_uk")
  @@index([tenantId, count(sort: Desc)], map: "search_logs_tenant_count_idx")
  @@map("search_logs")
}

model MerchantTicket {
  id         String    @id @default(uuid())
  ticketNo   String    @unique(map: "ticket_no") @map("ticket_no")
  merchantId String    @map("merchant_id")
  subject    String    @db.VarChar(200)
  status     String    @default("OPEN") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  closedAt   DateTime? @map("closed_at")

  @@index([merchantId], map: "idx_merchant")
  @@index([status], map: "idx_status")
  @@map("merchant_tickets")
}

model MerchantTicketMessage {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  senderType String   @default("MERCHANT") @map("sender_type") @db.VarChar(20)
  content    String   @db.Text
  images     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([ticketId], map: "idx_ticket")
  @@map("merchant_ticket_messages")
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(180)
  code      String   @db.VarChar(8)
  scope     String   @db.VarChar(40)
  tenantId  String?  @map("tenant_id")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, scope, tenantId, used], map: "email_otps_email_scope")
  @@index([expiresAt], map: "email_otps_expires")
  @@map("email_otps")
}

model Agent {
  id               String         @id @default(uuid())
  userId           String         @unique @map("user_id")
  shopName         String         @map("shop_name")
  shopSlug         String         @unique @map("shop_slug")
  shopLogo         String?        @map("shop_logo")
  shopSkin         String         @default("zen") @map("shop_skin")
  status           AgentStatus    @default(PENDING)
  balance          Decimal        @default(0.00) @db.Decimal(10, 2)
  totalEarnings    Decimal        @default(0.00) @map("total_earnings") @db.Decimal(10, 2)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  applyDescription String?        @map("apply_description") @db.Text
  contactEmail     String?        @map("contact_email")
  contactInfo      String?        @map("contact_info")
  shopNotice       String?        @map("shop_notice")
  withdrawAccounts String?        @map("withdraw_accounts") @db.Text
  emailNotify      Boolean        @default(true) @map("email_notify")
  notifyEmail      String?        @map("notify_email")
  orders           AgentOrder[]
  products         AgentProduct[]
  user             User           @relation(fields: [userId], references: [id])
  referredUsers    User[]         @relation("ReferredUsers")
  withdrawals      Withdrawal[]

  @@map("agents")
}

model AgentProduct {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  productId String   @map("product_id")
  markup    Decimal  @db.Decimal(10, 2)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([agentId, productId])
  @@index([productId], map: "agent_products_product_id_fkey")
  @@map("agent_products")
}

model AgentOrder {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  orderId   String   @unique @map("order_id")
  costPrice Decimal  @map("cost_price") @db.Decimal(10, 2)
  sellPrice Decimal  @map("sell_price") @db.Decimal(10, 2)
  profit    Decimal  @db.Decimal(10, 2)
  settled   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  agent     Agent    @relation(fields: [agentId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])

  @@index([agentId], map: "agent_orders_agent_id_fkey")
  @@map("agent_orders")
}

model Withdrawal {
  id          String           @id @default(uuid())
  agentId     String           @map("agent_id")
  amount      Decimal          @db.Decimal(10, 2)
  method      String
  account     String
  status      WithdrawalStatus @default(PENDING)
  processedAt DateTime?        @map("processed_at")
  remark      String?
  createdAt   DateTime         @default(now()) @map("created_at")
  agent       Agent            @relation(fields: [agentId], references: [id])

  @@index([agentId], map: "withdrawals_agent_id_fkey")
  @@map("withdrawals")
}

model Tenant {
  id           String         @id @default(uuid())
  userId       String         @unique @map("user_id")
  shopName     String         @map("shop_name")
  shopSlug     String         @unique @map("shop_slug")
  shopSkin     String         @default("zen") @map("shop_skin")
  shopLogo     String?        @map("shop_logo")
  shopNotice   String?        @map("shop_notice")
  contactEmail String?        @map("contact_email")
  contactInfo  String?        @map("contact_info")
  status       TenantStatus   @default(PENDING)
  reviewNote   String?        @map("review_note") @db.Text
  planId       String?        @map("plan_id")
  expireAt     DateTime?      @map("expire_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  orders       Order[]
  products     Product[]
  domains      TenantDomain[]
  settings     TenantSetting?
  user         User           @relation(fields: [userId], references: [id])

  @@map("tenants")
}

model TenantDomain {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  domain      String    @unique
  dnsVerified Boolean   @default(false) @map("dns_verified")
  sslIssued   Boolean   @default(false) @map("ssl_issued")
  isPrimary   Boolean   @default(false) @map("is_primary")
  verifiedAt  DateTime? @map("verified_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "tenant_domains_tenant_id_fkey")
  @@map("tenant_domains")
}

model TenantSetting {
  id                  String   @id @default(uuid())
  tenantId            String   @unique @map("tenant_id")
  alipayEnabled       Boolean  @default(false) @map("alipay_enabled")
  wechatEnabled       Boolean  @default(false) @map("wechat_enabled")
  usdtEnabled         Boolean  @default(false) @map("usdt_enabled")
  bscUsdtEnabled      Boolean  @default(false) @map("bsc_usdt_enabled")
  paymentConfig       String?  @map("payment_config") @db.Text
  notificationEnabled Boolean  @default(false) @map("notification_enabled")
  notificationText    String?  @map("notification_text")
  notificationLink    String?  @map("notification_link")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  systemSettings      String?  @map("system_settings") @db.LongText
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model Customer {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  email             String
  password          String
  username          String?
  avatar            String?
  emailVerified     Boolean   @default(false) @map("email_verified")
  verificationToken String?   @map("verification_token")
  resetToken        String?   @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  orders            Order[]
  tickets           Ticket[]

  @@unique([tenantId, email], map: "customers_tenant_email_unique")
  @@index([tenantId])
  @@map("customers")
}

model Merchant {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  shopName     String      @map("shop_name")
  isSuperAdmin Boolean     @default(false) @map("is_super_admin")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  planOrders   PlanOrder[]
  shop         Shop?

  @@map("merchants")
}

model Shop {
  id            String      @id @default(uuid())
  slug          String      @unique
  name          String
  merchantId    String      @unique @map("merchant_id")
  plan          ShopPlan    @default(FREE)
  trialEndsAt   DateTime    @map("trial_ends_at")
  planExpiresAt DateTime?   @map("plan_expires_at")
  status        ShopStatus  @default(ACTIVE)
  customDomain  String?     @map("custom_domain")
  logo          String?
  notice        String?
  skin          String      @default("classic")
  contactEmail  String?     @map("contact_email")
  settings      String?     @db.LongText
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  planOrders    PlanOrder[]
  merchant      Merchant    @relation(fields: [merchantId], references: [id])

  @@map("shops")
}

model PlanOrder {
  id            String    @id @default(uuid())
  merchantId    String    @map("merchant_id")
  shopId        String    @map("shop_id")
  plan          ShopPlan
  months        Int
  amount        Decimal   @db.Decimal(10, 2)
  paymentMethod String?   @map("payment_method")
  paymentStatus String    @default("PENDING") @map("payment_status")
  tradeNo       String?   @map("trade_no")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  merchant      Merchant  @relation(fields: [merchantId], references: [id])
  shop          Shop      @relation(fields: [shopId], references: [id])

  @@index([merchantId], map: "plan_orders_merchant_id_fkey")
  @@index([shopId], map: "plan_orders_shop_id_fkey")
  @@map("plan_orders")
}

model PlatformSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String?  @db.Text
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

model CustomTheme {
  id           String   @id @default(uuid())
  key          String   @unique
  name         String
  description  String?  @db.Text
  componentDir String   @map("component_dir")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("custom_themes")
}

model CustomThemeAssignment {
  id        String   @id @default(uuid())
  themeId   String   @map("theme_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([themeId, tenantId])
  @@map("custom_theme_assignments")
}

enum Role {
  USER
  AGENT
  ADMIN
  SUPER_ADMIN
  TENANT_ADMIN
}

enum Status {
  ACTIVE
  INACTIVE
  PENDING
}

enum CardStatus {
  AVAILABLE
  SOLD
  EXPIRED
}

enum OrderStatus {
  PENDING
  PAID
  COMPLETED
  CANCELLED
  REFUNDING
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum TicketType {
  ORDER_ISSUE
  CARD_ISSUE
  REFUND
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_SUPER_ADMIN
  COMPLETED
  CLOSED
}

enum AgentStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TenantStatus {
  PENDING
  REVIEWING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ShopPlan {
  FREE
  BASIC
  STANDARD
  PRO
}

enum ShopStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}
